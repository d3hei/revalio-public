# Copy to .env and adjust as needed.

# --- Postgres ---
POSTGRES_USER=revalio
POSTGRES_PASSWORD=revalio
POSTGRES_DB=revalio
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgres://revalio:revalio@localhost:5432/revalio

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- API ---
API_PORT=3001
API_HOST=0.0.0.0
NODE_ENV=development

# --- Web (Docker "app" profile only) ---
# Host port for the containerized web app (nginx). Dev (vite) uses 5173.
WEB_PORT=8088

# --- Sui ---
# Testnet gRPC fullnode endpoint (used by the indexer).
SUI_NETWORK=testnet
SUI_GRPC_URL=https://fullnode.testnet.sui.io:443
# Public JSON-RPC fallback (read-only helpers). Swap in a dedicated provider URL
# for continuous indexing to avoid public-node 429s.
SUI_RPC_URL=https://fullnode.testnet.sui.io:443
# RPC for on-demand DeFi position discovery (suix_getOwnedObjects). Point at
# MAINNET to see real DeFi protocols (Cetus/Scallop/Suilend/…). Defaults to
# SUI_RPC_URL when unset.
SUI_DEFI_RPC_URL=https://cetus-mainnet-endpoint.blockvision.org
# Comma-separated fallbacks if the primary DeFi RPC misses indexed objects.
SUI_DEFI_RPC_FALLBACKS=https://fullnode.mainnet.sui.io:443,https://rpc-mainnet.suiscan.xyz:443,https://cetus-suimain-e31f.mainnet.sui.rpcpool.com
# Only for the FIRST run on a fresh DB (containerized indexer / run-live.ps1);
# afterwards the indexer resumes from the stored watermark. Leave empty to resume.
SUI_FIRST_CHECKPOINT=

# --- Price feeds ---
PYTH_HERMES_URL=https://hermes.pyth.network
COINGECKO_API_BASE=https://api.coingecko.com/api/v3

# --- Mainnet indexer (optional profile: indexer-mainnet) ---
SUI_MAINNET_RPC_URL=https://fullnode.mainnet.sui.io:443
# Set once for a fresh DB; leave empty to resume watermark.
SUI_MAINNET_FIRST_CHECKPOINT=

# --- DeFi enrichment (optional BlockVision; native decoders are primary) ---
BLOCKVISION_API_KEY=
BLOCKVISION_API_BASE=https://api.blockvision.org/v2
# Comma-separated: cetus,navi,scallop. Empty = no BlockVision calls.
BLOCKVISION_PROTOCOLS=

# Ember Protocol vault API (mainnet positions + vault registry)
EMBER_VAULTS_API_BASE=https://vaults.api.sui-prod.bluefin.io
