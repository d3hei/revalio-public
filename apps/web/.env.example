# Base URL prefix for API calls from the browser.
# Leave EMPTY to use the Vite dev proxy (recommended): request paths already
# start with "/api", which the dev server forwards to the API.
# Set to an absolute origin (e.g. http://localhost:3001) only for no-proxy setups.
VITE_API_BASE=

# Origin the dev proxy forwards "/api" to. Change if the API runs elsewhere.
VITE_API_TARGET=http://localhost:3001

# Wallet + explorer network (mainnet for production)
VITE_SUI_NETWORK=mainnet
