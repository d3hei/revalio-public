# Copy to apps/indexer/.env (the indexer loads .env from its own directory).
# Host connection to the Dockerized Postgres from docker-compose.
DATABASE_URL=postgres://revalio:revalio@localhost:5432/revalio

# --- Live indexing (used by run-live.ps1) ---
# Fullnode RPC URL the indexer follows. The public testnet node rate-limits
# (HTTP 429) under sustained load; for continuous indexing point this at a
# dedicated provider (e.g. an API-key URL from your RPC provider of choice).
SUI_RPC_URL=https://fullnode.testnet.sui.io:443

# Optional: checkpoint to start from on the very FIRST bootstrap only.
# After that the framework resumes from the stored per-pipeline watermark, so
# you can leave this unset (or commented out) for normal live operation.
# SUI_FIRST_CHECKPOINT=342807490

# Optional: log verbosity filter. Default keeps output readable.
# RUST_LOG=info,sui_indexer_alt_framework::metrics=error
